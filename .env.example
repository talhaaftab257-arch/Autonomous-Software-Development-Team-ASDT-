# ASDT Environment Configuration

# FastAPI Settings
PORT=8000
HOST=0.0.0.0
DEBUG=True

# LLM API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Postgres Settings
# Local Docker value: postgresql://postgres:postgres@postgres:5432/asdt
# Local SQLite fallback: sqlite:///./asdt.db
DATABASE_URL=sqlite:///./asdt.db

# Redis Settings
# Local Docker value: redis://redis:6379/0
# Local In-memory fallback: memory
REDIS_URL=memory
